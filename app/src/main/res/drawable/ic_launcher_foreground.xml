<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Creamos un grupo para contener ambas letras.
      Aplicamos translateX y translateY para centrar el conjunto.
      He ajustado estos valores basándome en el tamaño de las letras.
    -->
    <group
        android:translateX="27"
        android:translateY="35">

        <!-- 1. Dibujamos la T PRIMERO para que quede al fondo (capa inferior) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M30,0 L53,0 L53,9 L42,9 L42,38 L32,38 L32,9 L30,9 Z" />

        <!-- 2. Dibujamos la V DESPUÉS para que tape el palito de la T (capa superior) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,0 L12,0 L18,23 L24,0 L36,0 L25,38 L11,38 Z" />

    </group>

</vector>